OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REQUEST_TIMEOUT=20
MAX_TEXT_CHARS=12000

# Default response language when --lang is not passed. Supported: ru, en.
# Priority: CLI --lang > DEFAULT_LANG > ru
DEFAULT_LANG=ru

# CORS for FastAPI (comma-separated origins, or * for any origin — dev-friendly default)
# ALLOWED_ORIGINS=*
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
